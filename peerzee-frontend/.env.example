# Example environment variables for Peerzee Frontend

# ============================================
# DEVELOPMENT (npm run dev)
# ============================================
# Use absolute URLs pointing to local backend
NEXT_PUBLIC_API_URL=http://localhost:9898
NEXT_PUBLIC_SOCKET_URL=http://localhost:9898

# ============================================
# PRODUCTION (Docker / Server)
# ============================================
# Copy this file to .env.production and use relative paths
# NEXT_PUBLIC_API_URL=/api
# NEXT_PUBLIC_SOCKET_URL=

# ============================================
# TURN SERVER (for WebRTC NAT traversal)
# ============================================
# Required for ~15% of users behind symmetric NAT
# NEXT_PUBLIC_TURN_URL=turn:your-turn-server:3478
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=

# Note:
# - .env.local is for npm dev (not tracked in git)
# - .env.production is for Docker builds (not tracked in git)
# - Create .env.production on your server with the production values
# - Socket URL can be empty to use window.location.origin
